{
  "schema_version": 1,
  "policy_id": "recovery_handoff",
  "mode": "operator_handoff",
  "authorization": {
    "authorized_defensive_use_only": true,
    "operator_acknowledgement_required": true,
    "remote_host_mutation_allowed": false
  },
  "freshness": {
    "enabled": true,
    "max_artifact_age_minutes": 10080,
    "future_clock_skew_tolerance_seconds": 600
  },
  "artifacts": [
    {
      "name": "recovery_handoff_summary_json",
      "path": "/var/lib/kali-hardening/recovery_handoff_summary.json",
      "required": true,
      "producer": "operator_handoff_notes"
    },
    {
      "name": "policy_validator_evidence_json",
      "path": "/var/log/host_vm_policy_validator_evidence.json",
      "required": true,
      "producer": "host_vm_policy_validator.py"
    }
  ],
  "privacy_boundaries": {
    "aggregate_only": true,
    "forbidden_fields": [
      "raw_logs",
      "packets",
      "captures",
      "credentials",
      "hostnames",
      "usernames",
      "secrets",
      "model_binaries",
      "datasets",
      "private_keys",
      "tokens"
    ]
  },
  "rollback": {
    "revert_files_only": true,
    "live_state_rollback_required": false,
    "notes": "Revert only the recovery handoff profile and documentation references; no live host, VM, firewall, service, network, IDS, credential, account, package, approval, or restore state is changed."
  }
}
