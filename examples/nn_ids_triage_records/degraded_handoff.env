# MINC - Passive NN IDS triage record fixture for degraded aggregate evidence.
# Defensive validation only; does not inspect live IDS, host, VM, hypervisor, packet, payload, or telemetry state.
triage_decision=degraded
release_ready=false
source_artifacts=nn_ids_release_readiness_summary.json,nn_ids_health_evidence.json,nn_ids_drift_evidence.json,nn_ids_model_card.md
artifact_hashes=manifest:nn_ids_posture_bundle_manifest.json#sha256
blocking_issues=drift evidence review is stale; model-card reviewer sign-off is pending
uncertainty_note=aggregate health evidence is a degraded analytical estimate until freshness and reviewer evidence are renewed
privacy_scope=aggregate-only; no raw telemetry or secrets
human_review_required=true
live_action_authorized=false
rollback_reference=docs/nn_ids_alert_triage_playbook.md#rollback
next_evidence_needed=refresh hosted static check evidence, drift review evidence, and model-card review evidence before release
owner=ids-maintainer
